{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "rootDir": "./scripts",
    "outDir": "./dist/scripts",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    
    "moduleResolution": "bundler",
    
    "allowJs": true,
    "declaration": false,
    "sourceMap": false,
    "removeComments": true
  },
  "include": ["scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}